    {
      "cell_type": "code",
      "source": [
        "class TicTacToeAgent:\n",
        "    def __init__(self):\n",
        "        self.q_table = {}   # state-action pairs\n",
        "        self.alpha = 0.1    # learning rate\n",
        "        self.gamma = 0.9    # discount factor\n",
        "\n",
        "    def get_action(self, state, empty_cells, epsilon=0.1):\n",
        "        if np.random.random() < epsilon:\n",
        "            return np.random.choice(empty_cells)   # explore\n",
        "        else:\n",
        "            # Return best action from Q-table (or random if unseen)\n",
        "            q_values = {a: self.q_table.get((state, a), 0) for a in empty_cells}\n",
        "            return max(q_values, key=q_values.get)  # exploit\n",
        "\n",
        "agent = TicTacToeAgent()\n",
        "print(\"TicTacToeAgent created successfully.\")\n",
        "print(f\"  Learning rate (alpha) : {agent.alpha}\")\n",
        "print(f\"  Discount factor (gamma): {agent.gamma}\")\n",
        "print(\"  Q-table starts empty вЂ” agent learns through play.\")"
      ],
