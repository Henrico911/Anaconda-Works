    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.feature_extraction.text import CountVectorizer\n",
        "from sklearn.naive_bayes import MultinomialNB\n",
        "\n",
        "emails = [\"Win free prize\", \"Meeting tomorrow\", \"Lottery winner\", \"Project deadline\"]\n",
        "labels = [\"spam\", \"not_spam\", \"spam\", \"not_spam\"]\n",
        "\n",
        "vectorizer = CountVectorizer()\n",
        "X = vectorizer.fit_transform(emails)\n",
        "\n",
        "spam_model = MultinomialNB()\n",
        "spam_model.fit(X, labels)\n",
        "\n",
        "new_email = [\"Congratulations! You won $1000\"]\n",
        "X_new = vectorizer.transform(new_email)\n",
        "print(\"Test email :\", new_email[0])\n",
        "print(\"Prediction :\", spam_model.predict(X_new))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
